@startuml GrowWise_View1_UserJourney
' ===============================
'  View 1: User Journey & Progress
'  Focus: User interactions and learning flow
' ===============================
!theme plain
skinparam classAttributeIconSize 0
skinparam linetype ortho
hide circle
skinparam nodesep 80
skinparam ranksep 80

title **GrowWise - View 1: User Journey & Progress**

class User {
    - user_id: int <<PK>>
    - email: string <<unique>>
    - password_hash: string
    - first_name: string
    - last_name: string
    - user_type: enum
    - created_at: timestamp
    - is_active: boolean
    + login(): boolean
    + logout(): void
    + updateProfile(data: json): boolean
}

class UserTrackSelection {
    - selection_id: int <<PK>>
    - user_id: int <<FK>>
    - track_id: int <<FK>>
    - selected_at: timestamp
    - is_active: boolean
    + selectTrack(): boolean
    + changeTrack(newTrackId: int): boolean
}

class LearningTrack {
    - track_id: int <<PK>>
    - track_name: string
    - description: text
    - difficulty_level: enum
    - estimated_duration_hours: int
    + getModules(): list
}

class LearningModule {
    - module_id: int <<PK>>
    - track_id: int <<FK>>
    - module_name: string
    - module_order: int
    - content_type: enum
    - estimated_duration_minutes: int
    + getContent(): json
}

class UserProgress {
    - progress_id: int <<PK>>
    - user_id: int <<FK>>
    - module_id: int <<FK>>
    - status: enum
    - started_at: timestamp
    - completed_at: timestamp
    - progress_percentage: decimal
    + startModule(): boolean
    + completeModule(): boolean
    + updateProgress(data: json): void
}

class SkillAssessment {
    - assessment_id: int <<PK>>
    - user_id: int <<FK>>
    - track_id: int <<FK>>
    - total_questions: int
    - score_percentage: decimal
    - completed_at: timestamp
    + startAssessment(): boolean
    + calculateScore(): decimal
}

class PersonalizedLearningPath {
    - path_id: int <<PK>>
    - user_id: int <<FK>>
    - track_id: int <<FK>>
    - assessment_id: int <<FK>>
    - path_data: json
    - status: enum
    + generatePath(assessmentId: int): boolean
    + getNextModule(): int
}

class UserInsights {
    - insight_id: int <<PK>>
    - user_id: int <<FK>>
    - insight_type: enum
    - insight_data: json
    - priority: enum
    + generateInsight(): void
    + getInsights(userId: int): list
}

' Relationships
User "1" -- "0..*" UserTrackSelection
UserTrackSelection "*" -- "1" LearningTrack
LearningTrack "1" *-- "1..*" LearningModule
User "1" -- "0..*" UserProgress
UserProgress "*" -- "1" LearningModule
User "1" -- "0..*" SkillAssessment
SkillAssessment "*" -- "1" LearningTrack
SkillAssessment "1" -- "0..*" PersonalizedLearningPath
User "1" -- "0..*" PersonalizedLearningPath
PersonalizedLearningPath "*" -- "1" LearningTrack
User "1" -- "0..*" UserInsights

note right of User
  User starts here:
  1. Selects a track
  2. Takes assessment
  3. Gets personalized path
  4. Completes modules
  5. Receives insights
end note

@enduml
